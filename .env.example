# Database (Local PostgreSQL)
DATABASE_URL="postgresql://localhost:5432/mahamordo"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."
# Optional model overrides (defaults: fast=claude-haiku-4-5-20251001)
# ANTHROPIC_FAST_MODEL="claude-haiku-4-5-20251001"
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# OpenAI — fortune post AI images (DALL-E 3)
OPENAI_API_KEY="sk-..."

# JWT Auth (generate secret: openssl rand -base64 32)
JWT_SECRET="your-secret-here"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS="7"

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth
# 1. ไปที่ https://console.cloud.google.com/apis/credentials
# 2. สร้าง OAuth 2.0 Client ID (Web application)
# 3. เพิ่ม Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Apple Sign-In — DISABLED (see docs/REMAINING.md, src/lib/auth-providers.ts)
# Do not add APPLE_* env vars until Apple login is explicitly re-enabled.

# Stripe (credits / subscription)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (password reset email in production)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@mahamordo.app"

# Uploads — fortune post + article cover images on server disk (see docs/DEPLOY_STORAGE.md)
# Dev default: data/uploads (no env needed)
# Production (DigitalOcean VPS): UPLOAD_DIR=/var/lib/mahamordo/uploads
UPLOAD_DIR="data/uploads"

# Articles — daily AI cron secret (used by /api/cron/articles/daily)
# Generate: openssl rand -hex 32
# Call from system cron / external pinger:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-domain/api/cron/articles/daily
# Enable in CMS at /cms/articles/settings (articles_cron_enabled = true)
CRON_SECRET="set-a-long-random-string-here"

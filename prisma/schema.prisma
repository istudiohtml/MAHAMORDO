generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  // For `prisma migrate dev` on shared/hosted MySQL where the app user has no
  // CREATE DATABASE privilege. Provision the shadow DB once and grant access:
  //   CREATE DATABASE mahamordo_shadow;
  //   GRANT ALL ON mahamordo_shadow.* TO 'mahamordo'@'localhost';
  // Optional in production — `migrate deploy` doesn't use the shadow DB.
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ── ORACLES ──────────────────────────────────────────────
// หมอดูแต่ละตัวละคร — จัดการได้จาก admin โดยไม่ต้อง redeploy
model Oracle {
  id              String   @id @default(cuid())
  slug            String   @unique // "yai-kham", "nang-fah", "mor-dum"
  name            String // "ยายขาม"
  title           String // "หมอดูผู้เฒ่าแห่งโหราศาสตร์ไทย"
  description     String   @db.Text // คำอธิบายสั้นๆ แสดงใน UI
  avatarUrl       String? // SVG icon path (preload / small avatar)
  posterUrl       String? // custom poster — overrides template jpg when set
  systemPrompt    String   @db.Text // full system prompt ส่งให้ Claude
  // VARCHAR(500) not TEXT — MySQL forbids DEFAULT on TEXT columns.
  // 500 chars is plenty for a single-line greeting message.
  initialGreeting String   @default("สวัสดีค่ะ") @db.VarChar(500)
  speciality      String // "โหราศาสตร์ไทย", "ไพ่ทาโรต์", "ศาสตร์มืด"
  creditCost      Int      @default(1) // ค่าใช้ต่อ session
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions FortuneSession[]

  @@map("oracles")
}

// ── USERS ──────────────────────────────────────────────────
model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  firstName  String?
  lastName   String?
  birthDate  DateTime?
  birthTime  String? // เวลาเกิด เช่น "14:30"
  birthPlace String? // สถานที่เกิด เช่น "กรุงเทพมหานคร"
  password   String? // hashed — null for OAuth users
  provider   String    @default("email") // "email" | "google" ("apple" reserved — disabled, see docs/REMAINING.md)
  image      String? // profile picture from OAuth
  role       UserRole  @default(USER)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  credits Int @default(0) // initial balance — signup bonus applied via settings

  // User Plan (FREE with limited features, or PAID)
  userPlan UserPlan @default(FREE)

  // Subscription (เช่น รายเดือน ดูได้ไม่จำกัด)
  subscriptionPlan      SubscriptionPlan @default(NONE)
  subscriptionExpiresAt DateTime?
  stripeCustomerId      String?          @unique // Stripe customer ID for webhook lookups

  // Free tier quotas (reset daily)
  aiOverviewQuotaUsed    Int      @default(0) // AI overview usage today (max 2 for free)
  aiOverviewQuotaResetAt DateTime @default(now()) // when quota resets

  // PDPA / Consent tracking (Thai Personal Data Protection Act 2562)
  consentVersion        String? // version of policy user agreed to (e.g. "1.0")
  consentAcceptedAt     DateTime? // when user accepted the policy
  marketingConsent      Boolean   @default(false) // optional analytics / marketing email
  dataExportRequestedAt DateTime? // last data-export request timestamp
  deletionRequestedAt   DateTime? // user-requested account deletion (soft)

  sessions         FortuneSession[]
  fortunePosts     FortunePost[]
  articles         Article[]
  creditLogs       CreditLog[]
  payments         Payment[]
  refreshTokens    RefreshToken[]
  passwordResets   PasswordReset[]
  quotaUsages      QuotaUsage[]
  subscriptionLogs SubscriptionLog[]
  dailyFortunes    DailyFortune[]

  @@map("users")
}

// ── PASSWORD RESETS ──────────────────────────────────────────
model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_resets")
}

// ── FORTUNE SESSIONS ────────────────────────────────────────
// 1 session = 1 การดูดวงครั้งนึง กับ oracle คนนึง
model FortuneSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  oracleId String
  oracle   Oracle @relation(fields: [oracleId], references: [id])

  topic     String? // หัวข้อ เช่น "ความรัก", "การงาน"
  birthDate DateTime? // วันเกิดผู้ใช้
  birthTime String? // เวลาเกิด เช่น "14:30"

  status        SessionStatus @default(ACTIVE)
  // Credit is charged once per session on the FIRST oracle reply (not on session open).
  // Subscription users get this flipped to true without decrementing credits.
  creditCharged Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  // Auto-expire after 24 hours — set explicitly in app code (MySQL has no
  // portable expression default for `now() + interval`).
  expiresAt     DateTime

  messages Message[]
  posts    FortunePost[]

  @@index([userId])
  @@index([expiresAt])
  @@map("fortune_sessions")
}

// ── FORTUNE POSTS ───────────────────────────────────────────
// โพสต์แชร์ผลดูดวง + รูปภาพ AI
model FortunePost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String?
  session   FortuneSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  title       String
  caption     String  @db.Text
  imageUrl    String
  imagePrompt String? @db.Text

  topic      String?
  oracleName String
  visibility PostVisibility @default(PRIVATE)

  zodiac     String?
  tradition  String? // chinese | western | korean
  timePeriod String?
  focus      String?
  platform   String?
  imageStyle String?
  imageSize  String?
  createMode String? // both | post | image | prompt
  quoteLine  String? // Thai quote on image (quote_card style)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("fortune_posts")
}

// ── ARTICLES (BLOG) ─────────────────────────────────────────
// บทความหน้าเว็บสาธารณะ — admin จัดการ, cron daily generate ได้
model Article {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  excerpt       String  @db.Text
  content       String  @db.Text // markdown body
  coverImageUrl String? // /api/uploads/articles/{id}.jpg
  coverPrompt   String? @db.Text // DALL-E prompt used (or for re-gen)

  category String // "horoscope" | "tarot" | "feng_shui" | "lucky" | "general"
  // Tag list stored as JSON — MySQL has no scalar array. Always shaped as string[].
  // Use the parseTags() helper from `@/lib/article-tags` for safe reads.
  tags     Json   @default("[]")

  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  source      String        @default("manual") // "manual" | "ai" | "cron"

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  readingMinutes Int? // estimated reading time
  viewCount      Int  @default(0)

  seoTitle       String?
  seoDescription String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ── MESSAGES ────────────────────────────────────────────────
model Message {
  id        String         @id @default(cuid())
  sessionId String
  session   FortuneSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role      MessageRole // USER หรือ ASSISTANT
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@map("messages")
}

// ── REFRESH TOKENS ──────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ── SYSTEM SETTINGS ─────────────────────────────────────────
// key-value store สำหรับ config ระบบ (SUPERADMIN จัดการ)
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique // "credit_price_thb", "free_credits_on_signup"
  value     String // เก็บเป็น string, parse ใน app
  label     String // ชื่อที่อ่านง่าย เช่น "ราคา 1 credit (บาท)"
  updatedAt DateTime @updatedAt
  updatedBy String? // userId ที่แก้ล่าสุด

  @@map("system_settings")
}

// ── CREDIT LOGS ─────────────────────────────────────────────
model CreditLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int // บวก = เติม, ลบ = ใช้
  reason    String // "signup_bonus", "session_start", "purchase_xxx"
  createdAt DateTime @default(now())

  @@map("credit_logs")
}

// ── PAYMENTS ────────────────────────────────────────────────
model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSessionId String  @unique
  stripePaymentId String?

  status  PaymentStatus @default(PENDING)
  amount  Int // ราคาเป็นสตางค์ (baht * 100)
  credits Int // จำนวนเครดิตที่ซื้อ

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  EXPIRED
}

// ── ENUMS ────────────────────────────────────────────────────
enum UserRole {
  USER // ผู้ใช้ทั่วไป
  ADMIN // จัดการ oracle, ดู dashboard
  SUPERADMIN // จัดการทุกอย่าง รวม user และ admin
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum PostVisibility {
  PRIVATE
  PUBLIC
}

enum SubscriptionPlan {
  NONE
  MONTHLY
  YEARLY
}

enum UserPlan {
  FREE // limited features
  PAID // unlimited (when subscribed or has credits)
}

// ── QUOTA USAGE ──────────────────────────────────────────
// Track daily quota usage for free tier users
model QuotaUsage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  quotaType String // "ai_overview", "daily_fortune_aspect"
  usedCount Int      @default(0)
  // Set explicitly in app code — MySQL DATE columns can't default to NOW()
  // (CURRENT_TIMESTAMP is a DATETIME, not DATE).
  date      DateTime @db.Date // YYYY-MM-DD
  createdAt DateTime @default(now())

  @@unique([userId, quotaType, date]) // one record per user per quota type per day
  @@map("quota_usages")
}

// ── SUBSCRIPTION LOGS ────────────────────────
// Track subscription lifecycle events
model SubscriptionLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  event     String // "created", "updated", "cancel_requested", "cancelled"
  planType  String? // "monthly" or "yearly"
  expiresAt DateTime?
  reason    String? // optional reason
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("subscription_logs")
}

// ── DAILY FORTUNE ────────────────────────────────────────────
// ดวงรายวัน — generated once per user per day, cached to save API costs
model DailyFortune {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date        DateTime @db.Date // YYYY-MM-DD (Thailand timezone)
  introLine   String   @db.Text // e.g. "ดวงวันนี้ของคุณมุ่งไปที่..."
  zoomWord    String   // highlight word e.g. "ความรัก"
  bodyText    String   @db.Text // main fortune reading
  luckyNumber String   // e.g. "3, 7"
  luckyColor  String   // e.g. "สีทอง"
  createdAt   DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("daily_fortunes")
}
